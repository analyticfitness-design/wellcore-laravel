# WellCore — .npmrc security hardening
# Contra supply chain attacks (ref: CVE-2026-45321 Mini Shai-Hulud / TanStack)

# Ancla el registry — evita que un proxy/cache envenenado intercepte descargas
registry=https://registry.npmjs.org/

# Fuerza auditoria en cada install
audit=true
audit-level=high

# Desactiva prompts de funding (ruido)
fund=false

# npm ci es el comando seguro en CI/prod — usa lockfile exacto
# Aquí definimos que las versiones en lockfile tienen prioridad
prefer-frozen-lockfile=true
