# =============================================================================
# WellCore Fitness — Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_NAME="WellCore Fitness"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://wellcore-laravel.test

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_STACK_CHANNELS=single
# Production with Sentry: LOG_STACK_CHANNELS=single,sentry
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database — MySQL (wellcore_fitness shared DB)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wellcore_fitness
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Cache / Session / Queue
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# SESSION_ENCRYPT=true        # Recomendado en producción — invalida sesiones existentes al activar
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=wellcore_

# -----------------------------------------------------------------------------
# Redis (Production — separate DBs per concern for isolation)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
# For Redis sessions: SESSION_DRIVER=redis, SESSION_CONNECTION=sessions
# For Redis queue:    QUEUE_CONNECTION=redis, REDIS_QUEUE_CONNECTION=queue
# For Redis cache:    CACHE_STORE=redis

# -----------------------------------------------------------------------------
# Mail / Mailjet
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=in-v3.mailjet.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@wellcorefitness.com
MAIL_FROM_NAME="WellCore Fitness"

# -----------------------------------------------------------------------------
# Broadcasting / Reverb (WebSocket server)
# Install with: composer require laravel/reverb
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=reverb

REVERB_APP_ID=wellcore
REVERB_APP_KEY=wellcore-key
REVERB_APP_SECRET=wellcore-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------------------------------------------------
# Wompi Payment Gateway (LATAM)
# Sandbox: https://sandbox.wompi.co/v1
# Production: https://production.wompi.co/v1
# -----------------------------------------------------------------------------
WOMPI_SANDBOX=true
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_BASE_URL=https://sandbox.wompi.co/v1

# -----------------------------------------------------------------------------
# Claude AI / Anthropic
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_BASE_URL=https://api.anthropic.com

# -----------------------------------------------------------------------------
# Push Notifications (VAPID — Web Push)
# Generate keys: php artisan webpush:vapid (or use web-push library CLI)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@wellcorefitness.com

# -----------------------------------------------------------------------------
# Error Tracking (Sentry — optional)
# Install: composer require sentry/sentry-laravel
# Then run: php artisan sentry:publish --dsn=<your-dsn>
# -----------------------------------------------------------------------------
ERROR_TRACKING_ENABLED=false
SENTRY_DSN=
SENTRY_SAMPLE_RATE=0.1
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_SENTRY_LEVEL=error
# When Sentry is installed, change LOG_STACK_CHANNELS to: single,sentry

# -----------------------------------------------------------------------------
# WellCore Performance Tuning
# -----------------------------------------------------------------------------
WC_CACHE_TTL=300
WC_QUERY_LOG=false
WC_SLOW_QUERY_MS=500
WC_MAX_UPLOAD_MB=10

# -----------------------------------------------------------------------------
# WellCore Strangler Fig — Feature Flags
# Values: 'laravel' or 'legacy'
# -----------------------------------------------------------------------------
FEATURE_AUTH=laravel
FEATURE_PUBLIC_PAGES=laravel
FEATURE_CLIENT_DASHBOARD=legacy
FEATURE_ADMIN_DASHBOARD=legacy
FEATURE_COACH_PORTAL=legacy
FEATURE_RISE_DASHBOARD=legacy

# Legacy PHP app URL (for Strangler Fig redirects)
WC_LEGACY_URL=http://wellcorefitness.test
WC_TOKEN_EXPIRY_DAYS=30

# -----------------------------------------------------------------------------
# AWS (optional — for S3 media storage)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Memcached (optional alternative to Redis)
# -----------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Google OAuth (for social login)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# -----------------------------------------------------------------------------
# Google Analytics
# -----------------------------------------------------------------------------
GA_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Meta (Facebook) Pixel & Conversions API
# -----------------------------------------------------------------------------
META_PIXEL_ID=
META_CONVERSIONS_TOKEN=
META_API_VERSION=v19.0
# META_TEST_EVENT_CODE=  # Only for sandbox testing

# -----------------------------------------------------------------------------
# Exercise GIF media (local path to GIF catalog folder)
# -----------------------------------------------------------------------------
GIF_BASE_PATH="/path/to/gif/catalog"

# Coach Contract Acceptance gate
# -----------------------------------------------
COACH_CONTRACT_GATE_ENABLED=true
COACH_CONTRACT_VERSION=1.0
COACH_CONTRACT_IS_DRAFT=false

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_COACH_STRATEGY_ENABLED=false

# Workout Player v2 — rollout gradual
WC_WORKOUT_PLAYER_V2=false
WC_WORKOUT_PLAYER_V2_PCT=0
WC_WORKOUT_PLAYER_V2_USERS=

# Profile Editor v2 — rollout gradual
WC_PROFILE_V2=false
WC_PROFILE_V2_PCT=0
WC_PROFILE_V2_USERS=

