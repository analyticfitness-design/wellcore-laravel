{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": ["artisan", "boost:mcp"]
        },
        "chrome-devtools": {
            "command": "npx",
            "args": ["--yes", "chrome-devtools-mcp@latest", "--browserUrl", "http://127.0.0.1:9222"]
        }
    }
}
